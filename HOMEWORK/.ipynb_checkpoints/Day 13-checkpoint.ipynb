    "#2\n",
    "\n",
    "num = int(input(\"Enter number : \"))\n",
    "convert = str(num)\n",
    "store = \"\"\n",
    "\n",
    "for i in range(len(convert)-1,-1,-1):\n",
    "    store =store + convert[i]\n",
    "print(store)\n",
    "\n",
    "if store == convert:\n",
    "    print(\"palindrome\")\n",
    "else:\n",
    "    print(\"not palindrome\")"
   ]
