   "source": [
    "word1 = input(\"Enter word1 : \").lower()\n",
    "word2 = input(\"Enter word2 : \").lower()\n",
    "\n",
    "count = 0\n",
    "\n",
    "for i in word1:\n",
    "    if i in word2:\n",
    "        count += 1\n",
    "\n",
    "if count == word2:\n",
    "    print(\"Anagram\")\n",
    "else:\n",
    "    print(\"Not Anagram\")"
   ]
